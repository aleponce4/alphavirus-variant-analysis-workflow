__pycache__/
*.pyc
*.pyo
*.pyd
.Python
env/
venv/
.venv/
pip-log.txt
pip-delete-this-directory.txt

# Exclude Jupyter Notebook checkpoints
.ipynb_checkpoints/
.ipynb

